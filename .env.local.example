# Supabase (shared with Sovereign Health OS)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (shared verified domain across all apps; per-app branding via display name)
# Format: "Display Name <noreply@verified-domain.com>"
# The email portion MUST use a domain that is verified in the Resend dashboard
# (https://resend.com/domains). Resend rejects sends from unverified domains
# with HTTP 422.
RESEND_API_KEY=your_resend_key
RESEND_FROM=EduIQ Sovereign Edition <noreply@your-verified-domain.com>

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key

# App
NEXT_PUBLIC_APP_URL=https://eduiq.vercel.app
